{
    "name": "ado-companion-extension",
    "version": "0.4.0",
    "private": true,
    "type": "module",
    "scripts": {
        "postinstall": "node scripts/bundle-vendor.mjs && wxt prepare",
        "dev": "node scripts/bundle-vendor.mjs && wxt",
        "dev:firefox": "node scripts/bundle-vendor.mjs && wxt -b firefox",
        "build": "node scripts/bundle-vendor.mjs && wxt prepare && tsc --noEmit && wxt build",
        "build:firefox": "node scripts/bundle-vendor.mjs && wxt prepare && tsc --noEmit && wxt build -b firefox",
        "zip": "node scripts/bundle-vendor.mjs && wxt zip",
        "zip:firefox": "node scripts/bundle-vendor.mjs && wxt zip -b firefox",
        "compile": "tsc --noEmit",
        "lint": "oxlint -c ../../oxlintrc.json --tsconfig tsconfig.lint.json --type-aware src/",
        "test": "vitest run"
    },
    "dependencies": {
        "@fluentui/tokens": "catalog:",
        "@fluentui/web-components": "catalog:",
        "dompurify": "catalog:",
        "highlight.js": "catalog:",
        "markdown-it": "catalog:",
        "mermaid": "catalog:",
        "solid-js": "catalog:"
    },
    "devDependencies": {
        "@solidjs/testing-library": "catalog:development",
        "@types/markdown-it": "catalog:development",
        "@types/node": "catalog:development",
        "@vitest/coverage-v8": "catalog:development",
        "@wxt-dev/module-solid": "catalog:development",
        "esbuild": "catalog:development",
        "jsdom": "catalog:development",
        "oxlint": "catalog:development",
        "oxlint-tsgolint": "catalog:development",
        "typescript": "catalog:development",
        "vite": "catalog:development",
        "vite-plugin-solid": "catalog:development",
        "vitest": "catalog:development",
        "wxt": "catalog:development"
    }
}
